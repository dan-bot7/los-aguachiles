generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PickupOrder {
  id            String            @id @default(cuid())
  customerName  String
  customerPhone String
  locationId    String
  locationName  String
  pickupDate    DateTime
  pickupTime    String
  notes         String?
  subtotalMxn   Int
  status        PickupOrderStatus @default(PENDING)
  source        String            @default("web")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  items         PickupOrderItem[]
}

model PickupOrderItem {
  id          String      @id @default(cuid())
  orderId     String
  menuItemId  String
  name        String
  quantity    Int
  unitPrice   Int
  lineTotal   Int
  order       PickupOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum PickupOrderStatus {
  PENDING
  CONFIRMED
  READY
  COMPLETED
  CANCELLED
}
